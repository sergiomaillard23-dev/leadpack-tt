# ─── Supabase Auth (cloud free tier — auth tokens only) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Railway Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── Upstash Redis (5-min pack timers) ────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── WiPay — wallet top-ups (credits) ────────────────────────────────────────
WIPAY_ACCOUNT_NUMBER=
WIPAY_API_KEY=
WIPAY_CALLBACK_SECRET=

# ─── WiPay — Legendary Pro subscriptions (separate merchant account) ──────────
WIPAY_MODE=mock                      # set to "live" in production
WIPAY_PRO_ACCOUNT_NUMBER=
WIPAY_PRO_API_KEY=
WIPAY_PRO_CALLBACK_SECRET=

# ─── WhatsApp Cloud API (outreach) ────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=          # Meta Business → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=             # Permanent token from Meta System User
WHATSAPP_WEBHOOK_VERIFY_TOKEN=     # Any random string you choose

# ─── Modal (background workers) ───────────────────────────────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@yourdomain.com  # comma-separated for multiple admins
